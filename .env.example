# ─── Database ────────────────────────────────────────────────────────────────
# Vercel Postgres / Neon connection string.
# Automatically injected when you link a Vercel Postgres database.
# For local dev a plain postgresql:// URL triggers the node-postgres fallback.
POSTGRES_URL=postgresql://user:password@localhost:5432/propbuilder

# Vercel Postgres also injects these; only needed if you use the raw PG driver directly.
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Full URL of the app (used for OAuth callback URLs and email links)
NEXTAUTH_URL=http://localhost:3000

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Override the model used for listing copy generation (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL_GENERATE=claude-haiku-4-5-20251001

# Override the model used for listing imports
# ANTHROPIC_MODEL_IMPORT=claude-sonnet-4-6

# ─── File storage ─────────────────────────────────────────────────────────────
# Vercel Blob — create a store at vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=

# ─── Email ────────────────────────────────────────────────────────────────────
# Any SMTP URL — e.g. smtp://user:pass@smtp.example.com:587
# Leave blank in dev to log emails to the console instead of sending.
EMAIL_SERVER=
EMAIL_FROM="PropBuilder <no-reply@example.com>"

# Receives admin alert emails (optional)
# SUPER_ADMIN_EMAIL=

# Set to "true" to show the contact link in the UI
NEXT_PUBLIC_EMAIL_CONFIGURED=false

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Display overrides — defaults are read from the Stripe product if omitted
# PLAN_PRICE_MONTHLY=99
# PLAN_PRICE_YEARLY=990
# PLAN_TRIAL_DAYS=14

# ─── Domain routing ───────────────────────────────────────────────────────────
# Apex domain for subdomain routing: {agency-slug}.ROOT_DOMAIN
ROOT_DOMAIN=property-landing-builder.vercel.app

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Bearer token Vercel Cron injects when it calls the scheduled routes.
# Cron endpoints return 503 when this is unset — set it in production.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Custom domain auto-registration (optional) ───────────────────────────────
# When set, saving a custom domain in agency settings also registers it
# via the Vercel Domains API automatically.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Enables "Sign in with Google" on the login page.
# GOOGLE_CLIENT_ID=

# ─── KV store (optional) ──────────────────────────────────────────────────────
# Vercel KV — used for rate limiting if configured.
# KV_URL=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret for the one-time setup route: POST /api/admin/setup { "secret": "…" }
SETUP_SECRET=

# Demo password shown on the login page for sandbox environments
# DEMO_PASSWORD=
