# ── Vercel Postgres ────────────────────────────────────────────────────────────
# Automatically injected when you link a Vercel Postgres database in the dashboard.
# For local dev, copy from: vercel env pull .env.local
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ── Vercel Blob ─────────────────────────────────────────────────────────────────
# Automatically injected when you link a Vercel Blob store.
BLOB_READ_WRITE_TOKEN=

# ── NextAuth / Auth.js ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Email (magic links for sellers) ────────────────────────────────────────────
# SMTP connection string, e.g. smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=
EMAIL_FROM="Property Builder <noreply@example.com>"

# ── Anthropic (existing) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Multi-tenancy ───────────────────────────────────────────────────────────────
# The root domain for subdomain routing (no protocol, no trailing slash)
ROOT_DOMAIN=property-landing-builder.vercel.app
